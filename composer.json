{
    "name": "company/sso",
    "description": "Shared OAuth/JWT SSO protocol for IdP server and client applications.",
    "type": "library",
    "license": "proprietary",
    "homepage": "https://github.com/asheek21-baaboo/sso-composer",
    "support": {
        "source": "https://github.com/asheek21-baaboo/sso-composer"
    },
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^7.0",
        "illuminate/auth": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Company\\Sso\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Company\\Sso\\Tests\\": "tests/"
        },
        "files": [
            "tests/Feature/Server/Fakes.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Company\\Sso\\SsoServiceProvider"
            ],
            "aliases": {
                "SsoUser": "Company\\Sso\\Facades\\SsoUser"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
